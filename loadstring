    lockBtn.Text = "LOCK: OFF"
    lockBtn.MouseButton1Click:Connect(function() 
        isLockActive = not isLockActive 
        if not isLockActive then currentTargetPlayer = nil end
        lockBtn.Text = isLockActive and "LOCK: ON" or "LOCK: OFF"
    end)
end

--// Render Loop
RunService.RenderStepped:Connect(function()
    if isLockActive then
        local targetPart = getTarget()
        if targetPart then
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, targetPart.Position), smoothness)
        end
    end
end)

