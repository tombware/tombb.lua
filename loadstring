local SETTINGS = {
    BoxColor = Color3.fromRGB(255, 0, 0),
    Background = Color3.fromRGB(10, 10, 10)
}

local Players, RunService = game:GetService("Players"), game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local isLockActive = false
local currentTargetPlayer = nil
local smoothness = 0.1

--// Persistent Targeting Logic
local function getTarget()
    -- 1. Check if current target is valid and alive
    if currentTargetPlayer and currentTargetPlayer.Character and currentTargetPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local humanoid = currentTargetPlayer.Character:FindFirstChildOfClass("Humanoid")
        if humanoid and humanoid.Health > 0 then
            return currentTargetPlayer.Character.HumanoidRootPart
        end
    end
    
    -- 2. If lost/dead, find the closest new target
    local closest, shortest = nil, 250
    local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
            if humanoid and humanoid.Health > 0 then
                local pos, onScreen = Camera:WorldToViewportPoint(player.Character.HumanoidRootPart.Position)
                if onScreen then
                    local dist = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                    if dist < shortest then
                        shortest = dist
                        closest = player.Character.HumanoidRootPart
                        currentTargetPlayer = player -- Save player reference
                    end
                end
            end
        end
    end
    return closest
end

